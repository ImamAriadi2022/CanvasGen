# Template Konfigurasi Lingkungan CanvasGen

# Pengaturan Aplikasi
APP_NAME=CanvasGen
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# Konfigurasi Model
MODEL_ID=runwayml/stable-diffusion-v1-5
DEVICE=cuda
PRECISION=fp16
SAFETY_CHECKER=True

# Token Autentikasi HuggingFace (Opsional untuk model publik, wajib untuk model privat/gated)
HF_TOKEN=masukkan_token_huggingface_anda_disini

# Pengaturan Direktori
OUTPUT_DIR=outputs
ASSETS_DIR=assets

# Parameter Generasi Bawaan
DEFAULT_WIDTH=512
DEFAULT_HEIGHT=512
DEFAULT_NUM_INFERENCE_STEPS=30
DEFAULT_GUIDANCE_SCALE=7.5
