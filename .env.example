# CanvasGen Environment Configuration Template

# Application Settings
APP_NAME=CanvasGen
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# Model Configuration
MODEL_ID=runwayml/stable-diffusion-v1-5
DEVICE=cuda
PRECISION=fp16
SAFETY_CHECKER=True

# HuggingFace Auth Token (Optional for public models, required for gated models)
HF_TOKEN=your_huggingface_token_here

# Directory Settings
OUTPUT_DIR=outputs
ASSETS_DIR=assets

# Default Generation Defaults
DEFAULT_WIDTH=512
DEFAULT_HEIGHT=512
DEFAULT_NUM_INFERENCE_STEPS=30
DEFAULT_GUIDANCE_SCALE=7.5
